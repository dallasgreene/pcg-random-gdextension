[configuration]

entry_symbol = "pcg_library_init"
compatibility_minimum = "4.3"
reloadable = false

; [icons]
; PcgRandom = "res://addons/pcg_random/icons/pcg_random.svg"

[libraries]
macos.debug = "res://addons/pcg_random/bin/macos/libpcg-random.macos.template_debug.dylib"
macos.release = "res://addons/pcg_random/bin/macos/libpcg-random.macos.template_release.dylib"

ios.arm64.debug = "res://addons/pcg_random/bin/ios/libpcg-random.ios.template_debug.arm64.dylib"
ios.arm64.release = "res://addons/pcg_random/bin/ios/libpcg-random.ios.template_release.arm64.dylib"

windows.x86_64.debug = "res://addons/pcg_random/bin/windows/pcg-random.windows.template_debug.x86_64.dll"
windows.x86_64.release = "res://addons/pcg_random/bin/windows/pcg-random.windows.template_release.x86_64.dll"

linux.x86_64.debug = "res://addons/pcg_random/bin/linux/libpcg-random.linux.template_debug.x86_64.so"
linux.x86_64.release = "res://addons/pcg_random/bin/linux/libpcg-random.linux.template_release.x86_64.so"
linux.arm64.debug = "res://addons/pcg_random/bin/linux/libpcg-random.linux.template_debug.arm64.so"
linux.arm64.release = "res://addons/pcg_random/bin/linux/libpcg-random.linux.template_release.arm64.so"
linux.rv64.debug = "res://addons/pcg_random/bin/linux/libpcg-random.linux.template_debug.rv64.so"
linux.rv64.release = "res://addons/pcg_random/bin/linux/libpcg-random.linux.template_release.rv64.so"

android.x86_64.debug = "res://addons/pcg_random/bin/android/libpcg-random.android.template_debug.x86_64.so"
android.x86_64.release = "res://addons/pcg_random/bin/android/libpcg-random.android.template_release.x86_64.so"
android.arm64.debug = "res://addons/pcg_random/bin/android/libpcg-random.android.template_debug.arm64.so"
android.arm64.release = "res://addons/pcg_random/bin/android/libpcg-random.android.template_release.arm64.so"

web.wasm32.debug = "res://addons/pcg_random/bin/web/libpcg-random.web.template_debug.wasm32.nothreads.wasm"
web.wasm32.release = "res://addons/pcg_random/bin/web/libpcg-random.web.template_release.wasm32.nothreads.wasm"
